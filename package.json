{
  "name": "central-dogma",
  "type": "module",
  "scripts": {
    "eslint": "eslint src --cache --cache-strategy content --cache-location node_modules/.cache/eslint/",
    "format": "biome format .",
    "check": "biome check .",
    "lint:fix": "bun run eslint --fix && bun run format --write && bun run check --write",
    "lint": "bun run eslint && bun run format && bun run check",
    "build": "tsc",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts"
  },
  "dependencies": {
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.4.0",
    "hono": "4.12.30",
    "umt": "4.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@swc/core": "1.15.43",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "bun-types": "1.3.14",
    "eslint": "10.7.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-unicorn": "71.1.0",
    "jest": "30.4.2",
    "ts-node": "10.9.2",
    "tsx": "4.23.1",
    "typescript": "6.0.3"
  }
}