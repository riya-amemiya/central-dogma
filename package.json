{
  "name": "central-dogma",
  "type": "module",
  "scripts": {
    "eslint": "eslint src --cache --cache-strategy content --cache-location node_modules/.cache/eslint/",
    "format": "biome format .",
    "check": "biome check .",
    "lint:fix": "bun run eslint --fix && bun run format --write && bun run check --write",
    "lint": "bun run eslint && bun run format && bun run check",
    "build": "tsc",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts"
  },
  "dependencies": {
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.4.0",
    "hono": "4.12.24",
    "umt": "4.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@swc/core": "1.15.40",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "bun-types": "1.3.14",
    "eslint": "10.4.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-unicorn": "65.0.0",
    "jest": "30.4.2",
    "ts-node": "10.9.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}